  <eml>
    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">120</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function damp = fcn(kappa,Phi)
kap1=kappa(1);kap2=kappa(2);kap3=kappa(3);
phi1=Phi(:,1);phi2=Phi(:,2);phi3=Phi(:,3);
damp=-[kap1*norm(phi1)^2,kap2*norm(phi2)^2,kap3*norm(phi3)^2];

</P>
      </eml>
    </state>
    <data SSID="4" name="kappa">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
