if flag==1
    Q_n=Q;dQ_n=dQ;
    delta_n=delta;ddelta_n=ddelta;
else
    Q_n=Q_old;dQ_n=dQ_old;
    delta_n=delta_old;ddelta_n=ddelta_old;
